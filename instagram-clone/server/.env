# ============================================
# پورت سرور
# ============================================
PORT=5000
NODE_ENV=development

# ============================================
# آدرس پایگاه داده MongoDB
# لوکال: mongodb://localhost:27017/instagram-clone
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/instagram-clone
# ============================================
MONGODB_URI=mongodb://localhost:27017/instagram-clone

# ============================================
# اطلاعات حساب Cloudinary
# این مقادیر را از داشبورد Cloudinary دریافت کنید
# ============================================
CLOUDINARY_CLOUD_NAME=mahdi
CLOUDINARY_API_KEY=986924417678316
CLOUDINARY_API_SECRET=*********************************

# ============================================
# کلید مخفی JWT (یک رشته تصادفی پیچیده)
# ============================================
JWT_SECRET=my_super_secret_jwt_key_2026_instagram_clone
JWT_EXPIRE=30d

# ============================================
# تنظیمات ایمیل (برای بازیابی رمز عبور)
# ============================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
